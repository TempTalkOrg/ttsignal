#!/bin/bash

script_dir=$(dirname $(realpath $0))

cd ${script_dir}
cp -rf ${script_dir}/../../src/js/index.js ${script_dir}/../../node_modules/ttsignal/
cmake   -DCMAKE_BUILD_TYPE=Release \
        -DTARGET_PLATFORM_LINUX:BOOL=ON \
        -DCMAKE_TOOLCHAIN_FILE=${script_dir}/../../src/cpp/cmake/linux.arm64.toolchain.cmake \
        ${script_dir}/../../src
make -j8
# strip — CMake 输出实际位于 node_modules/ttsignal/dist/build/Release/，
# 历史脚本指向 node_modules/ttsignal/Release/ 是 typo，导致 strip 一直 No such file
/opt/homebrew/bin/aarch64-unknown-linux-gnu-strip ${script_dir}/../../node_modules/ttsignal/dist/build/Release/ttsignal.linux.arm64.node