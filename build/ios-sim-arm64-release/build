#!/bin/bash
# Convenience wrapper — builds only this single iOS slice (simulator arm64).
# For the full xcframework pipeline, use ios/scripts/build-{deps,core,xcframework}.sh.
set -e
script_dir=$(dirname $(realpath $0))
repo_root="${script_dir}/../.."

cd "${script_dir}"
cmake -DBUILD_IOS_FRAMEWORK=ON \
      -DCMAKE_TOOLCHAIN_FILE="${repo_root}/src/cpp/cmake/ios.toolchain.cmake" \
      -DIOS_PLATFORM=SIMULATOR_ARM64 \
      -DIOS_DEPLOYMENT_TARGET=13.0 \
      -DCMAKE_BUILD_TYPE=Release \
      -DIOS_DEPS_DIR="${repo_root}/build/ios-deps/iphonesimulator-arm64/lib" \
      "${repo_root}/src"
cmake --build . --target ttsignal_ios -j8
